{"_meta": {"n_total": 48, "pulls": 1, "last_pull_utc": "2026-07-01T00:37:30+00:00", "newest_date": "2026-06-30T21:44:04Z", "oldest_date": "2026-06-30T15:01:43Z", "newest_id": "2072073710836588925"}, "posts": [{"id": "2072073710836588925", "handle": "DBro_FFB", "name": null, "text": "ABSOLUTELY", "date": "2026-06-30T21:44:04Z", "likes": 0, "url": "https://x.com/DBro_FFB/status/2072073710836588925", "kind": "tweet", "has_media": false, "social": "", "source": "x_list_scroll", "first_seen": "2026-07-01T00:37:30+00:00"}, {"id": "2072073074749685891", "handle": "BrettKollmann", "name": null, "text": "They need Knight to develop really really badly", "date": "2026-06-30T21:41:32Z", "likes": 0, "url": "https://x.com/BrettKollmann/status/2072073074749685891", "kind": "tweet", "has_media": false, "social": "", "source": "x_list_scroll", "first_seen": "2026-07-01T00:37:30+00:00"}, {"id": "2072070347143176416", "handle": "ScottBarrettDFB", "name": null, "text": "If I ever attend a sporting event that ends in 0-0 all of the players should be put to death", "date": "2026-06-30T21:30:42Z", "likes": 12, "url": "https://x.com/ScottBarrettDFB/status/2072070347143176416", "kind": "tweet", "has_media": false, "social": "", "source": "x_list_scroll", "first_seen": "2026-07-01T00:37:30+00:00"}, {"id": "2072069430515773779", "handle": "Clevta", "name": null, "text": "Being told that barring a last minute change here, Dean Wade will test the market in unrestricted free agency at 6 p.m ET, where Wade is expected to field interest from several playoff teams.", "date": "2026-06-30T21:27:04Z", "likes": 13, "url": "https://x.com/Clevta/status/2072069430515773779", "kind": "tweet", "has_media": false, "social": "", "source": "x_list_scroll", "first_seen": "2026-07-01T00:37:30+00:00"}, {"id": "2072069381832507564", "handle": "AlfredoABrown", "name": null, "text": "I'm almost done with Caleb Williams' charting for @RecepPerception, and I gotta say... Luther Burden should have a monster season for